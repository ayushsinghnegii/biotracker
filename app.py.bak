BASE_DIR = os.path.dirname(os.path.abspath(__file__))
PLANTNET_API_KEY = os.environ.get("PLANTNET_API_KEY", "2b10lhR4QtCn9O1aQAzSqDTV").strip()
PLANTNET_BASE = "https://my-api.plantnet.org/v2/identify/all"

DB_PATH = os.path.join(BASE_DIR, "biotracker.db")

def get_db():
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    return conn

def hash_password(password):
    return hashlib.sha256(password.encode("utf-8")).hexdigest()

def init_db():
    conn = get_db()
    cur = conn.cursor()
    cur.execute("""
        CREATE TABLE IF NOT EXISTS users (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            fullname TEXT NOT NULL,
            email TEXT UNIQUE NOT NULL,
            password_hash TEXT NOT NULL,
            organization TEXT DEFAULT '',
            role TEXT DEFAULT 'user',
            created_at TEXT NOT NULL
        )
    """)
    existing_cols = [r[1] for r in cur.execute("PRAGMA table_info(users)").fetchall()]
    if "role" not in existing_cols:
        cur.execute("ALTER TABLE users ADD COLUMN role TEXT DEFAULT 'user'")
    cur.execute("""
        CREATE TABLE IF NOT EXISTS scan_history (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_email TEXT,
            scan_type TEXT NOT NULL,
            species_name TEXT NOT NULL,
            scientific_name TEXT,
            category TEXT,
            confidence TEXT,
            file_name TEXT,
            created_at TEXT NOT NULL
        )
    """)
    cur.execute("""
        CREATE TABLE IF NOT EXISTS contact_messages (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            email TEXT NOT NULL,
            message TEXT NOT NULL,
            created_at TEXT NOT NULL
        )
    """)
    admin_email = "admin@biotracker.com"
    admin_password = "admin123"
    admin = cur.execute("SELECT id FROM users WHERE email=?", (admin_email,)).fetchone()
    if not admin:
        cur.execute(
            "INSERT INTO users(fullname,email,password_hash,organization,role,created_at) VALUES(?,?,?,?,?,?)",
            ("BioTracker Admin", admin_email, hash_password(admin_password), "Admin Panel", "admin", datetime.now().isoformat(timespec="seconds"))
        )
    else:
        cur.execute("UPDATE users SET role='admin' WHERE email=?", (admin_email,))
    conn.commit()
    conn.close()

def row_to_dict(row):
    return {k: row[k] for k in row.keys()}

init_db()

app = Flask(__name__, static_folder=BASE_DIR, static_url_path="")
app.config["MAX_CONTENT_LENGTH"] = 25 * 1024 * 1024

@app.after_request
def add_cors_headers(response):
    response.headers["Access-Control-Allow-Origin"] = "*"
    response.headers["Access-Control-Allow-Headers"] = "Content-Type"
    response.headers["Access-Control-Allow-Methods"] = "GET,POST,OPTIONS"
    return response

