@app.route("/api/identify-plant", methods=["OPTIONS"])
def identify_plant_options():
    return ("", 204)


def call_plantnet(image_bytes, filename, mimetype, organ):
    params = {
        "api-key": PLANTNET_API_KEY,
        "lang": "en",
        "include-related-images": "false",
        "no-reject": "true"
    }
    files = [("images", (filename, image_bytes, mimetype))]
    data = [("organs", organ)]
    response = requests.post(PLANTNET_BASE, params=params, files=files, data=data, timeout=45)
    content_type = response.headers.get("content-type", "")
    if "application/json" in content_type:
        payload = response.json()
    else:
        payload = {"message": response.text[:800]}
    return response.status_code, payload

@app.route("/api/identify-plant", methods=["POST"])
def identify_plant():
    try:
        if not PLANTNET_API_KEY:
            return jsonify({"error": "PlantNet API key missing. Set PLANTNET_API_KEY in app.py or environment."}), 500

        uploaded = request.files.get("image") or request.files.get("images")
        if not uploaded:
            return jsonify({"error": "No image received by backend. Please choose an image and click Analyze again."}), 400

        image_bytes = uploaded.read()
        if not image_bytes:
            return jsonify({"error": "Uploaded image is empty. Try another JPG/PNG image."}), 400

        filename = uploaded.filename or "plant-upload.jpg"
        mimetype = (uploaded.mimetype or "image/jpeg").lower()
        if mimetype == "image/jpg":
            mimetype = "image/jpeg"
        if mimetype not in ("image/jpeg", "image/png"):
            return jsonify({"error": f"PlantNet accepts JPG/PNG only. Your file type was {mimetype}. Convert it to JPG and try again."}), 400

        organs_to_try = ["flower", "leaf", "fruit", "bark", "habit"]
        best_payload = None
        best_score = -1.0
        errors = []

        for organ in organs_to_try:
            status, payload = call_plantnet(image_bytes, filename, mimetype, organ)
            if status >= 400:
                msg = payload.get("message") or payload.get("error") or str(payload)
                errors.append(f"{organ}: HTTP {status} - {msg}")
                continue
            results = payload.get("results") or []
            if results:
                score = float(results[0].get("score") or 0)
                if score > best_score:
                    best_score = score
                    best_payload = payload
                    best_payload["usedOrgan"] = organ

        if best_payload and best_payload.get("results"):
            return jsonify(best_payload)

        if errors:
            return jsonify({
                "error": "PlantNet API request failed. " + " | ".join(errors[:2]),
                "hint": "Check internet, API key quota, and run with run_project.bat / python app.py."
            }), 502

        return jsonify({"error": "PlantNet could not identify this plant. Use a clear close-up JPG/PNG of one flower or one leaf in good lighting."}), 422

    except requests.exceptions.Timeout:
        return jsonify({"error": "PlantNet request timed out. Check internet and try again."}), 504
    except requests.exceptions.RequestException as e:
        return jsonify({"error": f"Backend could not connect to PlantNet: {e}"}), 502
    except Exception as e:
        print("PlantNet backend error:", traceback.format_exc())
        return jsonify({"error": f"Backend error: {type(e).__name__}: {e}"}), 500


@app.route("/api/share-link", methods=["GET"])
def api_share_link():
    """Return the public ngrok URL if the launcher has created one; otherwise return local URLs."""
    share_file = os.path.join(BASE_DIR, "share_url.txt")
    lan_ip = get_lan_ip()
    public_url = ""
    if os.path.exists(share_file):
        try:
            public_url = open(share_file, "r", encoding="utf-8").read().strip()
        except Exception:
            public_url = ""
    if public_url and public_url.startswith("http"):
        return jsonify({
            "ok": True,
            "mode": "public",
            "url": public_url,
            "admin_url": public_url.rstrip("/") + "/admin.html",
            "message": "Public ngrok link is ready."
        })
    return jsonify({
        "ok": True,
        "mode": "local",
        "url": "http://127.0.0.1:5000",
        "lan_url": f"http://{lan_ip}:5000",
        "admin_url": "http://127.0.0.1:5000/admin.html",
        "message": "Public ngrok link not found. Start sharing with START_BIOTRACKER.bat after putting ngrok.exe in this folder or installing ngrok."
    })

@app.route("/<path:filename>")
def static_files(filename):
    return send_from_directory(BASE_DIR, filename)

def open_browser_later():
    time.sleep(1.5)
    webbrowser.open("http://127.0.0.1:5000")

if __name__ == "__main__":
    lan_ip = get_lan_ip()
    print("===========================================")
    print(" BioTracker backend running")
    print(" Your laptop URL: http://127.0.0.1:5000")
    print(f" Same Wi-Fi mobile/other laptop URL: http://{lan_ip}:5000")
    print(" Admin Panel: http://127.0.0.1:5000/admin.html")
    print(" Keep this window open while using the app")
    print(" Share link file: share_url.txt, if ngrok is running")
    print("===========================================")
    print("PlantNet key loaded:", bool(PLANTNET_API_KEY))
    threading.Thread(target=open_browser_later, daemon=True).start()
    app.run(host="0.0.0.0", port=5000, debug=False, use_reloader=False)
