def home():
    return send_from_directory(BASE_DIR, "index.html")

@app.route("/admin")
def admin_home():
    return send_from_directory(BASE_DIR, "admin.html")

@app.route("/admin.html")
def admin_html():
    return send_from_directory(BASE_DIR, "admin.html")

@app.route("/api/health", methods=["GET"])
def health():
    return jsonify({
        "ok": True,
        "message": "BioTracker backend is running",
        "plantnet_key_loaded": bool(PLANTNET_API_KEY),
        "plantnet_key_preview": (PLANTNET_API_KEY[:4] + "..." + PLANTNET_API_KEY[-4:]) if len(PLANTNET_API_KEY) > 8 else "missing"
    })


@app.route("/api/register", methods=["POST"])
def api_register():
    data = request.get_json(silent=True) or {}
    fullname = (data.get("fullname") or "").strip()
    email = (data.get("email") or "").strip().lower()
    password = data.get("password") or ""
    if not fullname or not email or not password:
        return jsonify({"error": "Please fill all fields."}), 400
    if len(password) < 6:
        return jsonify({"error": "Password must be at least 6 characters."}), 400
    try:
        conn = get_db()
        conn.execute(
            "INSERT INTO users(fullname,email,password_hash,role,created_at) VALUES(?,?,?,?,?)",
            (fullname, email, hash_password(password), "user", datetime.now().isoformat(timespec="seconds"))
        )
        conn.commit()
        conn.close()
        return jsonify({"ok": True, "message": "Account created successfully."})
    except sqlite3.IntegrityError:
        return jsonify({"error": "Email is already registered."}), 409

@app.route("/api/login", methods=["POST"])
def api_login():
    data = request.get_json(silent=True) or {}
    email = (data.get("email") or "").strip().lower()
    password = data.get("password") or ""
    conn = get_db()
    row = conn.execute("SELECT * FROM users WHERE email=?", (email,)).fetchone()
    conn.close()
    if not row or row["password_hash"] != hash_password(password):
        return jsonify({"error": "Invalid Email or Password"}), 401
    return jsonify({
        "ok": True,
        "user": {
            "fullname": row["fullname"],
            "email": row["email"],
            "organization": row["organization"] or "",
            "role": row["role"] or "user"
        }
    })

@app.route("/api/profile", methods=["POST"])
def api_profile():
    data = request.get_json(silent=True) or {}
    email = (data.get("email") or "").strip().lower()
    fullname = (data.get("fullname") or "").strip()
    organization = (data.get("organization") or "").strip()
    password = data.get("password") or ""
    if not email or not fullname:
        return jsonify({"error": "Name and email required."}), 400
    conn = get_db()
    if password:
        conn.execute("UPDATE users SET fullname=?, organization=?, password_hash=? WHERE email=?",
                     (fullname, organization, hash_password(password), email))
    else:
        conn.execute("UPDATE users SET fullname=?, organization=? WHERE email=?",
                     (fullname, organization, email))
    conn.commit()
    updated = conn.execute("SELECT fullname,email,organization,role FROM users WHERE email=?", (email,)).fetchone()
    conn.close()
    if not updated:
        return jsonify({"error": "User not found."}), 404
    return jsonify({"ok": True, "user": row_to_dict(updated)})

@app.route("/api/save-scan", methods=["POST"])
def api_save_scan():
    data = request.get_json(silent=True) or {}
    species = (data.get("species_name") or "Uploaded Image").strip()
    scan_type = (data.get("scan_type") or "scan").strip()
    conn = get_db()
    conn.execute("""
        INSERT INTO scan_history(user_email,scan_type,species_name,scientific_name,category,confidence,file_name,created_at)
        VALUES(?,?,?,?,?,?,?,?)
    """, (
        (data.get("user_email") or "guest").strip().lower(), scan_type, species,
        (data.get("scientific_name") or "").strip(), (data.get("category") or "").strip(),
        (data.get("confidence") or "").strip(), (data.get("file_name") or "").strip(),
        datetime.now().isoformat(timespec="seconds")
    ))
    conn.commit()
    conn.close()
    return jsonify({"ok": True})

@app.route("/api/history", methods=["GET"])
def api_history():
    email = (request.args.get("email") or "guest").strip().lower()
    conn = get_db()
    rows = conn.execute("""
        SELECT id, scan_type, species_name, scientific_name, category, confidence, file_name, created_at
        FROM scan_history
        WHERE user_email=?
        ORDER BY id DESC
        LIMIT 50
    """, (email,)).fetchall()
    conn.close()
    return jsonify({"ok": True, "items": [row_to_dict(r) for r in rows]})

@app.route("/api/stats", methods=["GET"])
def api_stats():
    email = (request.args.get("email") or "guest").strip().lower()
    conn = get_db()
    total = conn.execute("SELECT COUNT(*) AS c FROM scan_history WHERE user_email=?", (email,)).fetchone()["c"]
    plants = conn.execute("SELECT COUNT(*) AS c FROM scan_history WHERE user_email=? AND lower(category) LIKE '%plant%'", (email,)).fetchone()["c"]
    animals = conn.execute("SELECT COUNT(*) AS c FROM scan_history WHERE user_email=? AND lower(category) LIKE '%animal%'", (email,)).fetchone()["c"]
    messages = conn.execute("SELECT COUNT(*) AS c FROM contact_messages").fetchone()["c"]
    conn.close()
    return jsonify({"ok": True, "total_scans": total, "plant_scans": plants, "animal_scans": animals, "contact_messages": messages})

@app.route("/api/contact", methods=["POST"])
def api_contact():
    data = request.get_json(silent=True) or {}
    name = (data.get("name") or "").strip()
    email = (data.get("email") or "").strip().lower()
    message = (data.get("message") or "").strip()
    if not name or not email or not message:
        return jsonify({"error": "Please fill all contact fields."}), 400
    conn = get_db()
    conn.execute("INSERT INTO contact_messages(name,email,message,created_at) VALUES(?,?,?,?)",
                 (name, email, message, datetime.now().isoformat(timespec="seconds")))
    conn.commit()
    conn.close()
    return jsonify({"ok": True, "message": "Message saved in database."})



def is_admin_email(email):
    email = (email or "").strip().lower()
    if not email:
        return False
    conn = get_db()
    row = conn.execute("SELECT role FROM users WHERE email=?", (email,)).fetchone()
    conn.close()
    return bool(row and (row["role"] == "admin"))

@app.route("/api/admin/overview", methods=["GET"])
def api_admin_overview():
    admin_email = (request.args.get("email") or "").strip().lower()
    if not is_admin_email(admin_email):
        return jsonify({"error": "Admin access required."}), 403

    conn = get_db()
    total_users = conn.execute("SELECT COUNT(*) AS c FROM users").fetchone()["c"]
    total_scans = conn.execute("SELECT COUNT(*) AS c FROM scan_history").fetchone()["c"]
    plant_scans = conn.execute("SELECT COUNT(*) AS c FROM scan_history WHERE lower(category) LIKE '%plant%'").fetchone()["c"]
    animal_scans = conn.execute("SELECT COUNT(*) AS c FROM scan_history WHERE lower(category) LIKE '%animal%'").fetchone()["c"]
    total_messages = conn.execute("SELECT COUNT(*) AS c FROM contact_messages").fetchone()["c"]

    users = conn.execute("""
        SELECT id, fullname, email, organization, role, created_at
        FROM users
        ORDER BY id DESC
        LIMIT 25
    """).fetchall()
    scans = conn.execute("""
        SELECT id, user_email, scan_type, species_name, scientific_name, category, confidence, file_name, created_at
        FROM scan_history
        ORDER BY id DESC
        LIMIT 25
    """).fetchall()
    messages = conn.execute("""
        SELECT id, name, email, message, created_at
        FROM contact_messages
        ORDER BY id DESC
        LIMIT 25
    """).fetchall()
    top_species = conn.execute("""
        SELECT species_name, category, COUNT(*) AS count
        FROM scan_history
        GROUP BY species_name, category
        ORDER BY count DESC
        LIMIT 10
    """).fetchall()
    conn.close()

    return jsonify({
        "ok": True,
        "stats": {
            "total_users": total_users,
            "total_scans": total_scans,
            "plant_scans": plant_scans,
            "animal_scans": animal_scans,
            "total_messages": total_messages
        },
        "users": [row_to_dict(r) for r in users],
        "scans": [row_to_dict(r) for r in scans],
        "messages": [row_to_dict(r) for r in messages],
        "top_species": [row_to_dict(r) for r in top_species]
    })

@app.route("/api/admin/delete-user", methods=["POST"])
def api_admin_delete_user():
    data = request.get_json(silent=True) or {}
    admin_email = (data.get("admin_email") or "").strip().lower()
    target_email = (data.get("target_email") or "").strip().lower()
    if not is_admin_email(admin_email):
        return jsonify({"error": "Admin access required."}), 403
    if not target_email or target_email == "admin@biotracker.com":
        return jsonify({"error": "This user cannot be deleted."}), 400
    conn = get_db()
    conn.execute("DELETE FROM users WHERE email=? AND role!='admin'", (target_email,))
    conn.commit()
    conn.close()
    return jsonify({"ok": True, "message": "User deleted."})


